@{
    ViewData["Title"] = "About Us";
    Layout = "_Layout";
}

<div class="container mt-5 pt-5">
    <div class="row">
        <div class="col-12 text-center mb-5">
            <h1 class="display-4">About Us</h1>
            <p class="lead">Learn more about our company and mission</p>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-lg-6">
            <h2>Our Story</h2>
            <p>Founded in 2010, we started with a simple mission: to make business management accessible and efficient for companies of all sizes. What began as a small startup has grown into a global platform serving thousands of businesses worldwide.</p>
            <p>Our team of dedicated professionals works tirelessly to innovate and improve our platform, ensuring that our clients always have access to the best tools and features available.</p>
        </div>
        <div class="col-lg-6">
            <img src="/images/about-story.jpg" alt="Our Story" class="img-fluid rounded">
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-lg-4 mb-4">
            <div class="text-center">
                <i class="fas fa-bullseye fa-3x text-primary mb-3"></i>
                <h3>Our Mission</h3>
                <p>To empower businesses with intuitive tools that streamline operations and drive growth.</p>
            </div>
        </div>
        <div class="col-lg-4 mb-4">
            <div class="text-center">
                <i class="fas fa-eye fa-3x text-primary mb-3"></i>
                <h3>Our Vision</h3>
                <p>To be the world's most trusted platform for business management and collaboration.</p>
            </div>
        </div>
        <div class="col-lg-4 mb-4">
            <div class="text-center">
                <i class="fas fa-heart fa-3x text-primary mb-3"></i>
                <h3>Our Values</h3>
                <p>Innovation, Integrity, Customer Success, and Continuous Improvement.</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <h2 class="text-center mb-4">Our Leadership Team</h2>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card text-center">
                <img src="/images/team1.jpg" class="card-img-top" alt="Team Member">
                <div class="card-body">
                    <h5 class="card-title">John Doe</h5>
                    <p class="card-text text-muted">CEO & Founder</p>
                </div>
            </div>
        </div>
        <!-- Add more team members -->
    </div>
</div>