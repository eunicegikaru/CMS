@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<!-- Hero Section -->
<section id="home" class="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 hero-content" data-aos="fade-right">
                <h1>Empower Your Business with Smart Solutions</h1>
                <p>Streamline your operations, manage projects efficiently, and boost productivity with our comprehensive management platform.</p>
                <div class="hero-buttons">
                    <a href="#" class="btn-get-started" onclick="showRegisterModal()">
                        <i class="fas fa-rocket me-2"></i>Get Started Free
                    </a>
                    <a href="#" class="btn-watch-video">
                        <i class="fas fa-play me-2"></i>Watch Demo
                    </a>
                </div>
                <div class="mt-5">
                    <div class="row">
                        <div class="col-4">
                            <h3 class="text-white mb-0">10K+</h3>
                            <small>Active Users</small>
                        </div>
                        <div class="col-4">
                            <h3 class="text-white mb-0">5K+</h3>
                            <small>Projects Completed</small>
                        </div>
                        <div class="col-4">
                            <h3 class="text-white mb-0">98%</h3>
                            <small>Satisfaction Rate</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6" data-aos="fade-left">
                <div class="hero-image">
                    <img src="/images/hero-illustration.svg" alt="Hero Illustration" class="img-fluid">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section id="features" class="features">
    <div class="container">
        <div class="section-title" data-aos="fade-up">
            <h2>Powerful Features</h2>
            <p>Everything you need to manage your business effectively in one place</p>
        </div>
        <div class="row">
            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="100">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-tachometer-alt"></i>
                    </div>
                    <h3>Admin Dashboard</h3>
                    <p>Complete control over your business with advanced analytics, user management, and system configuration.</p>
                    <a href="#" class="feature-link">
                        Learn More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="200">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-users-cog"></i>
                    </div>
                    <h3>Manager Portal</h3>
                    <p>Efficiently manage your team, assign tasks, track performance, and generate insightful reports.</p>
                    <a href="#" class="feature-link">
                        Learn More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="300">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <h3>Client Portal</h3>
                    <p>Track your projects, view invoices, communicate with your team, and access documents anytime.</p>
                    <a href="#" class="feature-link">
                        Learn More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="400">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3>Advanced Analytics</h3>
                    <p>Make data-driven decisions with comprehensive analytics, custom reports, and real-time insights.</p>
                    <a href="#" class="feature-link">
                        Learn More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="500">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-file-invoice"></i>
                    </div>
                    <h3>Invoice Management</h3>
                    <p>Create, send, and track invoices seamlessly. Accept payments and manage your finances efficiently.</p>
                    <a href="#" class="feature-link">
                        Learn More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="600">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <h3>Time Tracking</h3>
                    <p>Track time spent on projects, monitor productivity, and generate accurate timesheets for billing.</p>
                    <a href="#" class="feature-link">
                        Learn More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="about">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4" data-aos="fade-right">
                <div class="about-image">
                    <img src="/images/about-us.jpg" alt="About Us" class="img-fluid">
                </div>
            </div>
            <div class="col-lg-6 about-content" data-aos="fade-left">
                <h2>Transforming Businesses Through Technology</h2>
                <p>We're on a mission to simplify business management and help companies of all sizes achieve their goals through innovative technology solutions.</p>
                <p>Our platform brings together all the tools you need to manage projects, teams, clients, and finances in one intuitive interface. Whether you're a small startup or a large enterprise, we have the right solution for you.</p>
                <div class="about-stats">
                    <div class="stat-item">
                        <span class="stat-number">15+</span>
                        <span class="stat-label">Years Experience</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">200+</span>
                        <span class="stat-label">Team Members</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">50+</span>
                        <span class="stat-label">Global Offices</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="services">
    <div class="container">
        <div class="section-title" data-aos="fade-up">
            <h2>Our Services</h2>
            <p>Comprehensive solutions tailored to your business needs</p>
        </div>
        <div class="row">
            <div class="col-lg-4 col-md-6 mb-4" data-aos="zoom-in" data-aos-delay="100">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-project-diagram"></i>
                    </div>
                    <h3>Project Management</h3>
                    <p>Plan, execute, and monitor projects with ease. Collaborate with team members and track progress in real-time.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="zoom-in" data-aos-delay="200">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Team Collaboration</h3>
                    <p>Foster seamless communication and collaboration within your team with integrated messaging and file sharing.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="zoom-in" data-aos-delay="300">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                    <h3>Analytics & Reporting</h3>
                    <p>Get actionable insights with comprehensive analytics and customizable reports to drive business growth.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Pricing Section -->
<section id="pricing" class="pricing">
    <div class="container">
        <div class="section-title" data-aos="fade-up">
            <h2>Simple, Transparent Pricing</h2>
            <p>Choose the plan that best fits your needs</p>
        </div>
        <div class="row">
            <div class="col-lg-4 col-md-6 mb-4" data-aos="flip-left" data-aos-delay="100">
                <div class="pricing-card">
                    <div class="pricing-header">
                        <h3>Starter</h3>
                        <div class="price">$29<span>/month</span></div>
                    </div>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check"></i> Up to 10 users</li>
                        <li><i class="fas fa-check"></i> 5 projects</li>
                        <li><i class="fas fa-check"></i> Basic analytics</li>
                        <li><i class="fas fa-check"></i> Email support</li>
                        <li><i class="fas fa-check"></i> 5GB storage</li>
                    </ul>
                    <a href="#" class="btn-pricing" onclick="showRegisterModal()">Get Started</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="flip-up" data-aos-delay="200">
                <div class="pricing-card popular">
                    <div class="popular-badge">Popular</div>
                    <div class="pricing-header">
                        <h3>Professional</h3>
                        <div class="price">$79<span>/month</span></div>
                    </div>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check"></i> Up to 50 users</li>
                        <li><i class="fas fa-check"></i> Unlimited projects</li>
                        <li><i class="fas fa-check"></i> Advanced analytics</li>
                        <li><i class="fas fa-check"></i> Priority support</li>
                        <li><i class="fas fa-check"></i> 50GB storage</li>
                        <li><i class="fas fa-check"></i> Custom reports</li>
                    </ul>
                    <a href="#" class="btn-pricing" onclick="showRegisterModal()">Get Started</a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="flip-right" data-aos-delay="300">
                <div class="pricing-card">
                    <div class="pricing-header">
                        <h3>Enterprise</h3>
                        <div class="price">$199<span>/month</span></div>
                    </div>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check"></i> Unlimited users</li>
                        <li><i class="fas fa-check"></i> Unlimited projects</li>
                        <li><i class="fas fa-check"></i> Enterprise analytics</li>
                        <li><i class="fas fa-check"></i> 24/7 phone support</li>
                        <li><i class="fas fa-check"></i> 500GB storage</li>
                        <li><i class="fas fa-check"></i> API access</li>
                        <li><i class="fas fa-check"></i> Custom integration</li>
                    </ul>
                    <a href="#" class="btn-pricing" onclick="showRegisterModal()">Contact Sales</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials">
    <div class="container">
        <div class="section-title text-white" data-aos="fade-up">
            <h2 class="text-white">What Our Clients Say</h2>
            <p class="text-white-50">Trusted by businesses worldwide</p>
        </div>
        <div class="row">
            <div class="col-lg-4" data-aos="fade-right" data-aos-delay="100">
                <div class="testimonial-card">
                    <div class="testimonial-content">
                        "This platform has transformed how we manage our projects. The team collaboration features are outstanding!"
                    </div>
                    <div class="testimonial-author">
                        <div class="author-avatar">
                            <img src="/images/avatar1.jpg" alt="John Smith">
                        </div>
                        <div class="author-info">
                            <h5>John Smith</h5>
                            <p>CEO, TechCorp</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                <div class="testimonial-card">
                    <div class="testimonial-content">
                        "The client portal is fantastic! I can track all my projects and invoices in one place. Highly recommended."
                    </div>
                    <div class="testimonial-author">
                        <div class="author-avatar">
                            <img src="/images/avatar2.jpg" alt="Sarah Johnson">
                        </div>
                        <div class="author-info">
                            <h5>Sarah Johnson</h5>
                            <p>Client, StartUp Inc</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4" data-aos="fade-left" data-aos-delay="300">
                <div class="testimonial-card">
                    <div class="testimonial-content">
                        "As a manager, the analytics and reporting features have been invaluable for making data-driven decisions."
                    </div>
                    <div class="testimonial-author">
                        <div class="author-avatar">
                            <img src="/images/avatar3.jpg" alt="Mike Chen">
                        </div>
                        <div class="author-info">
                            <h5>Mike Chen</h5>
                            <p>Product Manager</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta">
    <div class="container">
        <h2 data-aos="zoom-in">Ready to Get Started?</h2>
        <p data-aos="zoom-in" data-aos-delay="100">Join thousands of satisfied customers and take your business to the next level</p>
        <a href="#" class="btn-cta" data-aos="zoom-in" data-aos-delay="200" onclick="showRegisterModal()">
            Start Your Free Trial
        </a>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" class="features" style="padding: 80px 0;">
    <div class="container">
        <div class="section-title" data-aos="fade-up">
            <h2>Get In Touch</h2>
            <p>Have questions? We're here to help</p>
        </div>
        <div class="row">
            <div class="col-lg-6 mb-4" data-aos="fade-right">
                <form onsubmit="event.preventDefault(); sendMessage();">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <input type="text" class="form-control" placeholder="Your Name" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <input type="email" class="form-control" placeholder="Your Email" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Subject" required>
                    </div>
                    <div class="mb-3">
                        <textarea class="form-control" rows="5" placeholder="Your Message" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Send Message</button>
                </form>
            </div>
            <div class="col-lg-6" data-aos="fade-left">
                <div class="row">
                    <div class="col-sm-6 mb-4">
                        <div class="feature-card">
                            <i class="fas fa-map-marker-alt fa-2x text-primary mb-3"></i>
                            <h5>Visit Us</h5>
                            <p class="text-muted">123 Business Ave<br>Suite 100<br>San Francisco, CA 94105</p>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-4">
                        <div class="feature-card">
                            <i class="fas fa-phone fa-2x text-primary mb-3"></i>
                            <h5>Call Us</h5>
                            <p class="text-muted">+1 (555) 123-4567<br>Mon-Fri, 9am-6pm EST</p>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-4">
                        <div class="feature-card">
                            <i class="fas fa-envelope fa-2x text-primary mb-3"></i>
                            <h5>Email Us</h5>
                            <p class="text-muted">support@yourbrand.com<br>sales@yourbrand.com</p>
                        </div>
                    </div>
                    <div class="col-sm-6 mb-4">
                        <div class="feature-card">
                            <i class="fas fa-clock fa-2x text-primary mb-3"></i>
                            <h5>Business Hours</h5>
                            <p class="text-muted">Monday - Friday: 9am - 6pm<br>Saturday: 10am - 4pm</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function sendMessage() {
            alert('Thank you for your message! We will get back to you soon.');
        }
    </script>
}