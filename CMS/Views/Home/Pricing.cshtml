@{
    ViewData["Title"] = "Pricing";
    Layout = "_Layout";
}

<div class="container mt-5 pt-5">
    <div class="row">
        <div class="col-12 text-center mb-5">
            <h1 class="display-4">Simple, Transparent Pricing</h1>
            <p class="lead">Choose the plan that's right for your business</p>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="pricing-card text-center">
                <h3>Starter</h3>
                <div class="price">$29<span>/mo</span></div>
                <hr>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Up to 10 users</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>5 projects</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Basic analytics</li>
                </ul>
                <button class="btn btn-primary w-100" onclick="showRegisterModal()">Get Started</button>
            </div>
        </div>
        <!-- Add more pricing plans -->
    </div>
</div>