@{
    ViewData["Title"] = "Invoices";
    Layout = "_ClientLayout";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3">
            <i class="bi bi-receipt text-success me-2"></i>Invoices
        </h2>
        <div>
            <button class="btn btn-outline-primary me-2" onclick="exportInvoices()">
                <i class="bi bi-download"></i> Export
            </button>
            <button class="btn btn-primary" onclick="requestPaymentPlan()">
                <i class="bi bi-credit-card"></i> Payment Plan
            </button>
        </div>
    </div>

    <!-- Invoice Summary -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6>Total Billed</h6>
                    <h2 id="totalBilled">$0</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6>Total Paid</h6>
                    <h2 id="totalPaid">$0</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h6>Outstanding</h6>
                    <h2 id="outstanding">$0</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6>Next Due</h6>
                    <h2 id="nextDueDate">-</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Invoice Tabs -->
    <ul class="nav nav-tabs mb-4" id="invoiceTabs">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#all">All Invoices</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#pending">Pending <span class="badge bg-warning" id="pendingCount"></span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#paid">Paid <span class="badge bg-success" id="paidCount"></span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#overdue">Overdue <span class="badge bg-danger" id="overdueCount"></span></a>
        </li>
    </ul>

    <div class="tab-content">
        <!-- All Invoices Tab -->
        <div class="tab-pane fade show active" id="all">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Invoice #</th>
                                    <th>Project</th>
                                    <th>Issue Date</th>
                                    <th>Due Date</th>
                                    <th>Amount</th>
                                    <th>Paid</th>
                                    <th>Balance</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="invoicesTable">
                                <!-- Invoices will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pending Tab -->
        <div class="tab-pane fade" id="pending">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Invoice #</th>
                                    <th>Project</th>
                                    <th>Due Date</th>
                                    <th>Amount</th>
                                    <th>Days Left</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="pendingTable">
                                <!-- Pending invoices will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Paid Tab -->
        <div class="tab-pane fade" id="paid">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Invoice #</th>
                                    <th>Project</th>
                                    <th>Payment Date</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="paidTable">
                                <!-- Paid invoices will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Overdue Tab -->
        <div class="tab-pane fade" id="overdue">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Invoice #</th>
                                    <th>Project</th>
                                    <th>Due Date</th>
                                    <th>Amount</th>
                                    <th>Days Overdue</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="overdueTable">
                                <!-- Overdue invoices will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Payment History -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Payment History</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Invoice #</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th>Receipt</th>
                        </tr>
                    </thead>
                    <tbody id="paymentHistory">
                        <!-- Payment history will be loaded here -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Invoice Details Modal -->
<div class="modal fade" id="invoiceDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Invoice Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="invoiceDetailsContent">
                <!-- Invoice details will be loaded here -->
            </div>
            <div class="modal-footer">
                <button class="btn btn-success" onclick="payInvoice()">
                    <i class="bi bi-credit-card"></i> Pay Now
                </button>
                <button class="btn btn-primary" onclick="downloadInvoice()">
                    <i class="bi bi-download"></i> Download PDF
                </button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Make Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="paymentForm">
                    <input type="hidden" id="paymentInvoiceId">
                    <div class="mb-3">
                        <label class="form-label">Amount to Pay</label>
                        <input type="number" class="form-control" id="paymentAmount" step="0.01" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Payment Method</label>
                        <select class="form-select" id="paymentMethod" required>
                            <option value="">Select Method</option>
                            <option value="Credit Card">Credit Card</option>
                            <option value="Bank Transfer">Bank Transfer</option>
                            <option value="PayPal">PayPal</option>
                        </select>
                    </div>
                    <div class="mb-3" id="cardDetails" style="display: none;">
                        <label class="form-label">Card Number</label>
                        <input type="text" class="form-control" placeholder="**** **** **** ****">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" onclick="processPayment()">Process Payment</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentInvoiceId = null;

        $(document).ready(function() {
            loadInvoices();
            loadInvoiceSummary();
            loadPaymentHistory();

            $('#paymentMethod').change(function() {
                if ($(this).val() === 'Credit Card') {
                    $('#cardDetails').slideDown();
                } else {
                    $('#cardDetails').slideUp();
                }
            });
        });

        function loadInvoices() {
            $.get('/api/client/invoices', function(invoices) {
                displayAllInvoices(invoices);
                displayPendingInvoices(invoices.filter(i => i.status === 'Pending'));
                displayPaidInvoices(invoices.filter(i => i.status === 'Paid'));
                displayOverdueInvoices(invoices.filter(i => i.status === 'Overdue'));

                $('#pendingCount').text(invoices.filter(i => i.status === 'Pending').length);
                $('#paidCount').text(invoices.filter(i => i.status === 'Paid').length);
                $('#overdueCount').text(invoices.filter(i => i.status === 'Overdue').length);
            });
        }

        function loadInvoiceSummary() {
            $.get('/api/client/invoices/summary', function(summary) {
                $('#totalBilled').text('$' + summary.totalBilled.toLocaleString());
                $('#totalPaid').text('$' + summary.totalPaid.toLocaleString());
                $('#outstanding').text('$' + summary.outstanding.toLocaleString());
                $('#nextDueDate').text(summary.nextDueDate ? formatDate(summary.nextDueDate) : 'None');
            });
        }

        function displayAllInvoices(invoices) {
            let html = '';
            invoices.forEach(inv => {
                html += generateInvoiceRow(inv);
            });
            $('#invoicesTable').html(html || '<tr><td colspan="9" class="text-center">No invoices found</td></tr>');
        }

        function displayPendingInvoices(invoices) {
            let html = '';
            invoices.forEach(inv => {
                let daysLeft = calculateDaysRemaining(inv.dueDate);
                html += `
                    <tr>
                        <td><strong>${inv.invoiceNumber}</strong></td>
                        <td>${inv.project}</td>
                        <td>${formatDate(inv.dueDate)}</td>
                        <td>$${inv.totalAmount.toLocaleString()}</td>
                        <td><span class="badge bg-${daysLeft <= 7 ? 'warning' : 'info'}">${daysLeft} days</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="viewInvoice(${inv.id})">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-success" onclick="openPaymentModal(${inv.id}, ${inv.balanceDue})">
                                <i class="bi bi-credit-card"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });
            $('#pendingTable').html(html || '<tr><td colspan="6" class="text-center">No pending invoices</td></tr>');
        }

        function displayPaidInvoices(invoices) {
            let html = '';
            invoices.forEach(inv => {
                html += `
                    <tr>
                        <td><strong>${inv.invoiceNumber}</strong></td>
                        <td>${inv.project}</td>
                        <td>${formatDate(inv.paymentDate)}</td>
                        <td>$${inv.totalAmount.toLocaleString()}</td>
                        <td>${inv.paymentMethod || 'N/A'}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="viewInvoice(${inv.id})">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-success" onclick="downloadInvoice(${inv.id})">
                                <i class="bi bi-download"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });
            $('#paidTable').html(html || '<tr><td colspan="6" class="text-center">No paid invoices</td></tr>');
        }

        function displayOverdueInvoices(invoices) {
            let html = '';
            invoices.forEach(inv => {
                let daysOverdue = calculateDaysOverdue(inv.dueDate);
                html += `
                    <tr class="table-danger">
                        <td><strong>${inv.invoiceNumber}</strong></td>
                        <td>${inv.project}</td>
                        <td>${formatDate(inv.dueDate)}</td>
                        <td>$${inv.totalAmount.toLocaleString()}</td>
                        <td><span class="badge bg-danger">${daysOverdue} days</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="viewInvoice(${inv.id})">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="openPaymentModal(${inv.id}, ${inv.balanceDue})">
                                <i class="bi bi-credit-card"></i> Pay Now
                            </button>
                        </td>
                    </tr>
                `;
            });
            $('#overdueTable').html(html || '<tr><td colspan="6" class="text-center">No overdue invoices</td></tr>');
        }

        function generateInvoiceRow(inv) {
            let statusClass = inv.status === 'Paid' ? 'success' :
                             inv.status === 'Pending' ? 'warning' : 'danger';
            return `
                <tr class="${inv.status === 'Overdue' ? 'table-danger' : ''}">
                    <td><strong>${inv.invoiceNumber}</strong></td>
                    <td>${inv.project}</td>
                    <td>${formatDate(inv.issueDate)}</td>
                    <td>${formatDate(inv.dueDate)}</td>
                    <td>$${inv.totalAmount.toLocaleString()}</td>
                    <td>$${inv.amountPaid.toLocaleString()}</td>
                    <td>$${inv.balanceDue.toLocaleString()}</td>
                    <td><span class="badge bg-${statusClass}">${inv.status}</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" onclick="viewInvoice(${inv.id})">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-success" onclick="downloadInvoice(${inv.id})">
                            <i class="bi bi-download"></i>
                        </button>
                        ${inv.status !== 'Paid' ? `
                            <button class="btn btn-sm btn-success" onclick="openPaymentModal(${inv.id}, ${inv.balanceDue})">
                                <i class="bi bi-credit-card"></i>
                            </button>
                        ` : ''}
                    </td>
                </tr>
            `;
        }

        function loadPaymentHistory() {
            $.get('/api/client/invoices/payment-history', function(payments) {
                let html = '';
                payments.forEach(p => {
                    html += `
                        <tr>
                            <td>${formatDate(p.paymentDate)}</td>
                            <td><strong>${p.invoiceNumber}</strong></td>
                            <td>$${p.amountPaid.toLocaleString()}</td>
                            <td>${p.paymentMethod || 'N/A'}</td>
                            <td><span class="badge bg-success">Completed</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" onclick="downloadReceipt(${p.id})">
                                    <i class="bi bi-receipt"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
                $('#paymentHistory').html(html || '<tr><td colspan="6" class="text-center">No payment history</td></tr>');
            });
        }

        function viewInvoice(id) {
            $.get(`/api/client/invoices/${id}`, function(invoice) {
                let itemsHtml = '';
                invoice.items.forEach(item => {
                    itemsHtml += `
                        <tr>
                            <td>${item.description}</td>
                            <td class="text-center">${item.quantity}</td>
                            <td class="text-end">$${item.unitPrice.toFixed(2)}</td>
                            <td class="text-end">$${item.amount.toFixed(2)}</td>
                        </tr>
                    `;
                });

                let html = `
                    <div class="container-fluid">
                        <div class="row mb-4">
                            <div class="col-6">
                                <h5>${invoice.invoiceNumber}</h5>
                                <p class="text-muted">Issue Date: ${formatDate(invoice.issueDate)}</p>
                            </div>
                            <div class="col-6 text-end">
                                <h5>Balance Due</h5>
                                <h3 class="text-${invoice.status === 'Paid' ? 'success' : 'danger'}">$${invoice.balanceDue.toLocaleString()}</h3>
                                <span class="badge bg-${invoice.status === 'Paid' ? 'success' : 'warning'}">${invoice.status}</span>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-12">
                                <h6>Bill To:</h6>
                                <p>${invoice.clientName}<br>${invoice.clientEmail}</p>
                            </div>
                        </div>

                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Description</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${itemsHtml}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Subtotal:</strong></td>
                                    <td class="text-end">$${invoice.subtotal.toFixed(2)}</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Tax (${invoice.taxRate}%):</strong></td>
                                    <td class="text-end">$${invoice.taxAmount.toFixed(2)}</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                    <td class="text-end"><strong>$${invoice.totalAmount.toFixed(2)}</strong></td>
                                </tr>
                            </tfoot>
                        </table>

                        ${invoice.notes ? `
                            <div class="mt-3">
                                <strong>Notes:</strong>
                                <p class="text-muted">${invoice.notes}</p>
                            </div>
                        ` : ''}
                    </div>
                `;

                $('#invoiceDetailsContent').html(html);
                $('#invoiceDetailsModal').modal('show');
            });
        }

        function openPaymentModal(invoiceId, balance) {
            currentInvoiceId = invoiceId;
            $('#paymentInvoiceId').val(invoiceId);
            $('#paymentAmount').val(balance);
            $('#paymentAmount').attr('max', balance);
            $('#paymentModal').modal('show');
        }

        function processPayment() {
            const payment = {
                invoiceId: currentInvoiceId,
                amount: $('#paymentAmount').val(),
                method: $('#paymentMethod').val()
            };

            if (!payment.amount || payment.amount <= 0) {
                alert('Please enter a valid amount');
                return;
            }

            if (!payment.method) {
                alert('Please select a payment method');
                return;
            }

            $.ajax({
                url: `/api/client/invoices/${currentInvoiceId}/pay`,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payment),
                success: function() {
                    $('#paymentModal').modal('hide');
                    $('#paymentForm')[0].reset();
                    loadInvoices();
                    loadInvoiceSummary();
                    loadPaymentHistory();
                    showNotification('Payment processed successfully', 'success');
                },
                error: function(xhr) {
                    showNotification('Error processing payment: ' + xhr.responseText, 'error');
                }
            });
        }

        function downloadInvoice(id) {
            window.location.href = `/api/client/invoices/${id}/pdf`;
        }

        function downloadReceipt(id) {
            window.location.href = `/api/client/invoices/receipt/${id}`;
        }

        function exportInvoices() {
            window.location.href = '/api/client/invoices/export';
        }

        function requestPaymentPlan() {
            alert('Payment plan request form would open here');
        }

        function payInvoice() {
            $('#invoiceDetailsModal').modal('hide');
            openPaymentModal(currentInvoiceId, $('#invoiceDetailsModal').data('balance'));
        }

        function calculateDaysRemaining(dateString) {
            const due = new Date(dateString);
            const today = new Date();
            const diffTime = due - today;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            return diffDays > 0 ? diffDays : 0;
        }

        function calculateDaysOverdue(dateString) {
            const due = new Date(dateString);
            const today = new Date();
            const diffTime = today - due;
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            return diffDays > 0 ? diffDays : 0;
        }

        function formatDate(dateString) {
            return new Date(dateString).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
            });
        }

        function showNotification(message, type) {
            alert(message);
        }
    </script>
}