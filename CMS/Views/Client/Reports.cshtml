@{
    ViewData["Title"] = "Reports";
    Layout = "_ClientLayout";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3">
            <i class="bi bi-file-earmark-bar-graph text-info me-2"></i>Reports & Analytics
        </h2>
        <div>
            <button class="btn btn-outline-primary me-2" onclick="scheduleReport()">
                <i class="bi bi-clock"></i> Schedule Report
            </button>
            <button class="btn btn-primary" onclick="generateCustomReport()">
                <i class="bi bi-plus-circle"></i> Custom Report
            </button>
        </div>
    </div>

    <!-- Report Categories -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100" onclick="loadReport('project-status')" style="cursor: pointer;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Project Status</h6>
                            <h3 class="text-white mb-0">Overview</h3>
                        </div>
                        <i class="bi bi-folder-check fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white h-100" onclick="loadReport('financial')" style="cursor: pointer;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Financial Summary</h6>
                            <h3 class="text-white mb-0">Invoices & Payments</h3>
                        </div>
                        <i class="bi bi-cash-stack fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white h-100" onclick="loadReport('activity')" style="cursor: pointer;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Activity Log</h6>
                            <h3 class="text-white mb-0">Recent Activities</h3>
                        </div>
                        <i class="bi bi-clock-history fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white h-100" onclick="loadReport('milestones')" style="cursor: pointer;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Milestones</h6>
                            <h3 class="text-white mb-0">Progress Tracking</h3>
                        </div>
                        <i class="bi bi-flag fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Report Filters -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <label class="form-label">Report Type</label>
                    <select class="form-select" id="reportType" onchange="changeReportType()">
                        <option value="project-status">Project Status Report</option>
                        <option value="financial">Financial Report</option>
                        <option value="activity">Activity Report</option>
                        <option value="milestones">Milestones Report</option>
                        <option value="custom">Custom Report</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Period</label>
                    <select class="form-select" id="reportPeriod" onchange="loadCurrentReport()">
                        <option value="30">Last 30 Days</option>
                        <option value="90" selected>Last 90 Days</option>
                        <option value="180">Last 6 Months</option>
                        <option value="365">Last Year</option>
                        <option value="custom">Custom Range</option>
                    </select>
                </div>
                <div class="col-md-2" id="customDateRange" style="display: none;">
                    <label class="form-label">From</label>
                    <input type="date" class="form-control" id="dateFrom">
                </div>
                <div class="col-md-2" id="customDateRangeTo" style="display: none;">
                    <label class="form-label">To</label>
                    <input type="date" class="form-control" id="dateTo">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Project</label>
                    <select class="form-select" id="projectFilter">
                        <option value="">All Projects</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary me-2" onclick="loadCurrentReport()">
                        <i class="bi bi-search"></i> Generate
                    </button>
                    <button class="btn btn-outline-success" onclick="exportReport()">
                        <i class="bi bi-download"></i> Export
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Report Content -->
    <div class="row" id="reportContent">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0" id="reportTitle">Project Status Report</h5>
                    <div>
                        <span class="badge bg-info me-2" id="reportDate"></span>
                        <button class="btn btn-sm btn-outline-primary" onclick="refreshReport()">
                            <i class="bi bi-arrow-repeat"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Summary Cards -->
                    <div class="row mb-4" id="reportSummary">
                        <!-- Dynamic summary cards -->
                    </div>

                    <!-- Charts -->
                    <div class="row mb-4">
                        <div class="col-md-8">
                            <div class="card">
                                <div class="card-body">
                                    <canvas id="reportChart" height="300"></canvas>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <canvas id="reportPieChart" height="250"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Data Table -->
                    <div class="table-responsive">
                        <table class="table table-hover" id="reportTable">
                            <thead id="reportTableHeader">
                                <!-- Dynamic headers -->
                            </thead>
                            <tbody id="reportTableBody">
                                <!-- Dynamic data -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scheduled Reports -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history me-2"></i>Scheduled Reports
                    </h5>
                    <button class="btn btn-sm btn-outline-primary" onclick="manageSchedules()">
                        Manage Schedules
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Report Name</th>
                                    <th>Frequency</th>
                                    <th>Next Run</th>
                                    <th>Format</th>
                                    <th>Recipients</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="scheduledReports">
                                <!-- Scheduled reports will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Schedule Report Modal -->
<div class="modal fade" id="scheduleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Schedule Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="scheduleForm">
                    <div class="mb-3">
                        <label class="form-label">Report Type</label>
                        <select class="form-select" id="scheduleReportType" required>
                            <option value="project-status">Project Status Report</option>
                            <option value="financial">Financial Report</option>
                            <option value="activity">Activity Report</option>
                            <option value="milestones">Milestones Report</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Frequency</label>
                        <select class="form-select" id="scheduleFrequency" required>
                            <option value="daily">Daily</option>
                            <option value="weekly">Weekly</option>
                            <option value="monthly">Monthly</option>
                            <option value="quarterly">Quarterly</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Format</label>
                        <select class="form-select" id="scheduleFormat" required>
                            <option value="pdf">PDF</option>
                            <option value="excel">Excel</option>
                            <option value="csv">CSV</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email Recipients</label>
                        <input type="email" class="form-control" id="scheduleEmails"
                               placeholder="Enter email addresses (comma separated)" multiple required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <input type="text" class="form-control" id="scheduleSubject"
                               value="Scheduled Report - Your Company">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveSchedule()">Schedule Report</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let reportChart, reportPieChart;
        let currentReportType = 'project-status';

        $(document).ready(function() {
            loadProjects();
            loadScheduledReports();
            loadReport('project-status');

            $('#reportPeriod').change(function() {
                if ($(this).val() === 'custom') {
                    $('#customDateRange, #customDateRangeTo').show();
                } else {
                    $('#customDateRange, #customDateRangeTo').hide();
                    loadCurrentReport();
                }
            });
        });

        function loadProjects() {
            $.get('/api/client/projects', function(projects) {
                let options = '<option value="">All Projects</option>';
                projects.forEach(p => {
                    options += `<option value="${p.id}">${p.projectName}</option>`;
                });
                $('#projectFilter').html(options);
            });
        }

        function loadReport(type) {
            currentReportType = type;
            $('#reportTitle').text(getReportTitle(type));

            const period = $('#reportPeriod').val();
            const projectId = $('#projectFilter').val();

            let url = `/api/client/reports/${type}?period=${period}`;
            if (projectId) url += `&projectId=${projectId}`;

            if (period === 'custom') {
                const from = $('#dateFrom').val();
                const to = $('#dateTo').val();
                if (from && to) {
                    url += `&from=${from}&to=${to}`;
                }
            }

            $.get(url, function(data) {
                displayReportSummary(data.summary);
                updateReportChart(data);
                updateReportTable(data);
                $('#reportDate').text(`Generated: ${new Date().toLocaleString()}`);
            });
        }

        function loadCurrentReport() {
            loadReport(currentReportType);
        }

        function getReportTitle(type) {
            const titles = {
                'project-status': 'Project Status Report',
                'financial': 'Financial Report',
                'activity': 'Activity Report',
                'milestones': 'Milestones Report',
                'custom': 'Custom Report'
            };
            return titles[type] || 'Report';
        }

        function displayReportSummary(summary) {
            if (!summary) return;

            let html = '';
            for (let [key, value] of Object.entries(summary)) {
                let bgClass = 'bg-primary';
                if (key.includes('paid') || key.includes('completed')) bgClass = 'bg-success';
                if (key.includes('pending')) bgClass = 'bg-warning';
                if (key.includes('overdue')) bgClass = 'bg-danger';

                html += `
                    <div class="col-md-3 mb-3">
                        <div class="card ${bgClass} text-white">
                            <div class="card-body">
                                <h6 class="text-white-50">${formatLabel(key)}</h6>
                                <h3 class="text-white mb-0">${value}</h3>
                            </div>
                        </div>
                    </div>
                `;
            }
            $('#reportSummary').html(html);
        }

        function updateReportChart(data) {
            const ctx = document.getElementById('reportChart').getContext('2d');
            const pieCtx = document.getElementById('reportPieChart').getContext('2d');

            if (reportChart) reportChart.destroy();
            if (reportPieChart) reportPieChart.destroy();

            // Main Chart
            reportChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.chartLabels || [],
                    datasets: [{
                        label: 'Value',
                        data: data.chartData || [],
                        borderColor: '#4e73df',
                        backgroundColor: 'rgba(78, 115, 223, 0.05)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });

            // Pie Chart
            if (data.pieData) {
                reportPieChart = new Chart(pieCtx, {
                    type: 'doughnut',
                    data: {
                        labels: data.pieLabels || [],
                        datasets: [{
                            data: data.pieData || [],
                            backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b']
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false
                    }
                });
            }
        }

        function updateReportTable(data) {
            if (!data.tableHeaders || !data.tableData) return;

            // Update headers
            let headersHtml = '';
            data.tableHeaders.forEach(h => {
                headersHtml += `<th>${h}</th>`;
            });
            $('#reportTableHeader').html(headersHtml);

            // Update body
            let bodyHtml = '';
            data.tableData.forEach(row => {
                bodyHtml += '<tr>';
                data.tableHeaders.forEach(header => {
                    bodyHtml += `<td>${row[header] || '-'}</td>`;
                });
                bodyHtml += '</tr>';
            });
            $('#reportTableBody').html(bodyHtml);
        }

        function loadScheduledReports() {
            $.get('/api/client/reports/scheduled', function(schedules) {
                let html = '';
                schedules.forEach(s => {
                    html += `
                        <tr>
                            <td>${getReportTitle(s.type)}</td>
                            <td><span class="badge bg-info">${s.frequency}</span></td>
                            <td>${formatDate(s.nextRun)}</td>
                            <td><span class="badge bg-secondary">${s.format.toUpperCase()}</span></td>
                            <td>${s.recipients}</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" onclick="editSchedule(${s.id})">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteSchedule(${s.id})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
                $('#scheduledReports').html(html);
            });
        }

        function changeReportType() {
            currentReportType = $('#reportType').val();
            loadReport(currentReportType);
        }

        function scheduleReport() {
            $('#scheduleModal').modal('show');
        }

        function saveSchedule() {
            const schedule = {
                reportType: $('#scheduleReportType').val(),
                frequency: $('#scheduleFrequency').val(),
                format: $('#scheduleFormat').val(),
                recipients: $('#scheduleEmails').val().split(',').map(e => e.trim()),
                subject: $('#scheduleSubject').val()
            };

            $.ajax({
                url: '/api/client/reports/schedule',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(schedule),
                success: function() {
                    $('#scheduleModal').modal('hide');
                    $('#scheduleForm')[0].reset();
                    loadScheduledReports();
                    showNotification('Report scheduled successfully', 'success');
                },
                error: function(xhr) {
                    showNotification('Error scheduling report: ' + xhr.responseText, 'error');
                }
            });
        }

        function generateCustomReport() {
            $('#reportType').val('custom');
            changeReportType();
        }

        function exportReport() {
            const type = currentReportType;
            const period = $('#reportPeriod').val();
            const projectId = $('#projectFilter').val();

            let url = `/api/client/reports/export/${type}?period=${period}`;
            if (projectId) url += `&projectId=${projectId}`;

            window.location.href = url;
        }

        function refreshReport() {
            loadCurrentReport();
        }

        function manageSchedules() {
            alert('Schedule management panel would open here');
        }

        function editSchedule(id) {
            alert(`Edit schedule ${id}`);
        }

        function deleteSchedule(id) {
            if (confirm('Are you sure you want to delete this scheduled report?')) {
                $.ajax({
                    url: `/api/client/reports/schedule/${id}`,
                    type: 'DELETE',
                    success: function() {
                        loadScheduledReports();
                        showNotification('Schedule deleted', 'success');
                    }
                });
            }
        }

        function formatLabel(key) {
            return key.replace(/([A-Z])/g, ' $1')
                     .replace(/^./, str => str.toUpperCase());
        }

        function formatDate(dateString) {
            return new Date(dateString).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
            });
        }

        function showNotification(message, type) {
            alert(message);
        }
    </script>
}