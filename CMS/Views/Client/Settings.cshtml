@{
    ViewData["Title"] = "Settings";
    Layout = "_ClientLayout";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3">
            <i class="bi bi-gear text-secondary me-2"></i>Settings
        </h2>
    </div>

    <div class="row">
        <!-- Settings Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="list-group list-group-flush">
                    <a href="#account" class="list-group-item list-group-item-action active" data-bs-toggle="list">
                        <i class="bi bi-person me-2"></i>Account Settings
                    </a>
                    <a href="#notifications" class="list-group-item list-group-item-action" data-bs-toggle="list">
                        <i class="bi bi-bell me-2"></i>Notifications
                    </a>
                    <a href="#billing" class="list-group-item list-group-item-action" data-bs-toggle="list">
                        <i class="bi bi-credit-card me-2"></i>Billing & Payments
                    </a>
                    <a href="#team" class="list-group-item list-group-item-action" data-bs-toggle="list">
                        <i class="bi bi-people me-2"></i>Team Members
                    </a>
                    <a href="#api" class="list-group-item list-group-item-action" data-bs-toggle="list">
                        <i class="bi bi-code-square me-2"></i>API Access
                    </a>
                    <a href="#security" class="list-group-item list-group-item-action" data-bs-toggle="list">
                        <i class="bi bi-shield-lock me-2"></i>Security
                    </a>
                    <a href="#integrations" class="list-group-item list-group-item-action" data-bs-toggle="list">
                        <i class="bi bi-grid-3x3-gap-fill me-2"></i>Integrations
                    </a>
                </div>
            </div>
        </div>

        <!-- Settings Content -->
        <div class="col-md-9">
            <div class="tab-content">
                <!-- Account Settings -->
                <div class="tab-pane fade show active" id="account">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Account Settings</h5>
                        </div>
                        <div class="card-body">
                            <form id="accountSettingsForm">
                                <h6 class="mb-3">Basic Information</h6>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Display Name</label>
                                        <input type="text" class="form-control" value="John Doe">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Email Address</label>
                                        <input type="email" class="form-control" value="john@example.com">
                                    </div>
                                </div>

                                <h6 class="mb-3 mt-4">Company Information</h6>
                                <div class="mb-3">
                                    <label class="form-label">Company Name</label>
                                    <input type="text" class="form-control" value="Acme Corporation">
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Industry</label>
                                        <input type="text" class="form-control" value="Technology">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Company Size</label>
                                        <select class="form-select">
                                            <option>1-10 employees</option>
                                            <option selected>11-50 employees</option>
                                            <option>51-200 employees</option>
                                            <option>201-500 employees</option>
                                            <option>500+ employees</option>
                                        </select>
                                    </div>
                                </div>

                                <h6 class="mb-3 mt-4">Contact Information</h6>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Phone Number</label>
                                        <input type="tel" class="form-control" value="+1 (555) 123-4567">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Alternative Phone</label>
                                        <input type="tel" class="form-control" value="+1 (555) 987-6543">
                                    </div>
                                </div>

                                <h6 class="mb-3 mt-4">Address Information</h6>
                                <div class="mb-3">
                                    <label class="form-label">Street Address</label>
                                    <input type="text" class="form-control" value="123 Business Ave">
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label class="form-label">City</label>
                                        <input type="text" class="form-control" value="San Francisco">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">State</label>
                                        <input type="text" class="form-control" value="CA">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">ZIP Code</label>
                                        <input type="text" class="form-control" value="94105">
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary">Save Changes</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Notifications -->
                <div class="tab-pane fade" id="notifications">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Notification Preferences</h5>
                        </div>
                        <div class="card-body">
                            <h6 class="mb-3">Email Notifications</h6>

                            <div class="mb-4">
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="emailProjectUpdates" checked>
                                    <label class="form-check-label">Project Updates</label>
                                    <div class="text-muted small">Receive notifications when projects are updated</div>
                                </div>

                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="emailInvoices" checked>
                                    <label class="form-check-label">Invoice Alerts</label>
                                    <div class="text-muted small">Get notified about new invoices and payment status</div>
                                </div>

                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="emailMessages" checked>
                                    <label class="form-check-label">New Messages</label>
                                    <div class="text-muted small">Receive email when you get new messages</div>
                                </div>

                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="emailMarketing">
                                    <label class="form-check-label">Marketing & Promotions</label>
                                    <div class="text-muted small">Receive offers and product updates</div>
                                </div>
                            </div>

                            <h6 class="mb-3">Push Notifications</h6>

                            <div class="mb-4">
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="pushProjectUpdates" checked>
                                    <label class="form-check-label">Browser Push Notifications</label>
                                    <div class="text-muted small">Get real-time notifications in your browser</div>
                                </div>

                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="pushDeadlines" checked>
                                    <label class="form-check-label">Deadline Reminders</label>
                                    <div class="text-muted small">Remind me before project deadlines</div>
                                </div>
                            </div>

                            <h6 class="mb-3">Notification Schedule</h6>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Do Not Disturb Start</label>
                                    <input type="time" class="form-control" value="22:00">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Do Not Disturb End</label>
                                    <input type="time" class="form-control" value="08:00">
                                </div>
                            </div>

                            <button class="btn btn-primary">Save Preferences</button>
                        </div>
                    </div>
                </div>

                <!-- Billing & Payments -->
                <div class="tab-pane fade" id="billing">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Billing & Payments</h5>
                            <button class="btn btn-sm btn-primary" onclick="addPaymentMethod()">
                                <i class="bi bi-plus"></i> Add Payment Method
                            </button>
                        </div>
                        <div class="card-body">
                            <h6 class="mb-3">Current Plan</h6>
                            <div class="alert alert-info d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>Professional Plan</strong>
                                    <p class="mb-0 text-muted">$79/month · Next billing: April 15, 2024</p>
                                </div>
                                <button class="btn btn-sm btn-outline-primary" onclick="changePlan()">Change Plan</button>
                            </div>

                            <h6 class="mb-3 mt-4">Payment Methods</h6>
                            <div class="row" id="paymentMethods">
                                <div class="col-md-6">
                                    <div class="card mb-3 border-success">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between">
                                                <div>
                                                    <i class="bi bi-credit-card-2-front fs-2 text-primary"></i>
                                                    <h6 class="mt-2">•••• •••• •••• 4242</h6>
                                                    <p class="text-muted small mb-0">Expires 05/25</p>
                                                </div>
                                                <div>
                                                    <span class="badge bg-success">Default</span>
                                                </div>
                                            </div>
                                            <div class="mt-3">
                                                <button class="btn btn-sm btn-outline-primary">Edit</button>
                                                <button class="btn btn-sm btn-outline-danger">Remove</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <h6 class="mb-3 mt-4">Billing History</h6>
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Invoice #</th>
                                            <th>Amount</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="billingHistory">
                                        <!-- Billing history will be loaded here -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Team Members -->
                <div class="tab-pane fade" id="team">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Team Members</h5>
                            <button class="btn btn-sm btn-primary" onclick="inviteMember()">
                                <i class="bi bi-person-plus"></i> Invite Member
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Role</th>
                                            <th>Status</th>
                                            <th>Last Active</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="teamMembers">
                                        <!-- Team members will be loaded here -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- API Access -->
                <div class="tab-pane fade" id="api">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">API Access</h5>
                            <button class="btn btn-sm btn-primary" onclick="generateApiKey()">
                                <i class="bi bi-key"></i> Generate New Key
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle"></i>
                                Keep your API keys secure. Never share them publicly.
                            </div>

                            <h6 class="mb-3">Your API Keys</h6>
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Key</th>
                                            <th>Created</th>
                                            <th>Last Used</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="apiKeys">
                                        <!-- API keys will be loaded here -->
                                    </tbody>
                                </table>
                            </div>

                            <h6 class="mb-3 mt-4">API Usage</h6>
                            <div class="progress mb-3" style="height: 25px;">
                                <div class="progress-bar" style="width: 45%">4,500 / 10,000 requests</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Security -->
                <div class="tab-pane fade" id="security">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Security Settings</h5>
                        </div>
                        <div class="card-body">
                            <h6 class="mb-3">Two-Factor Authentication</h6>
                            <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-light rounded">
                                <div>
                                    <strong>Secure your account with 2FA</strong>
                                    <p class="mb-0 text-muted">Add an extra layer of security</p>
                                </div>
                                <button class="btn btn-primary" onclick="setup2FA()">Enable 2FA</button>
                            </div>

                            <h6 class="mb-3">Session Management</h6>
                            <div class="list-group mb-4" id="securitySessions">
                                <!-- Sessions will be loaded here -->
                            </div>

                            <h6 class="mb-3">Login History</h6>
                            <div class="table-responsive mb-4">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Date & Time</th>
                                            <th>IP Address</th>
                                            <th>Device</th>
                                            <th>Location</th>
                                        </tr>
                                    </thead>
                                    <tbody id="securityLoginHistory">
                                        <!-- Login history will be loaded here -->
                                    </tbody>
                                </table>
                            </div>

                            <h6 class="mb-3">Activity Log</h6>
                            <div class="timeline" id="securityActivityLog">
                                <!-- Activity log will be loaded here -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Integrations -->
                <div class="tab-pane fade" id="integrations">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Integrations</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <i class="bi bi-slack fs-1 text-primary me-3"></i>
                                                <div>
                                                    <h6 class="mb-0">Slack</h6>
                                                    <small class="text-muted">Connect your Slack workspace</small>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-primary w-100">Connect</button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <i class="bi bi-google fs-1 text-primary me-3"></i>
                                                <div>
                                                    <h6 class="mb-0">Google Drive</h6>
                                                    <small class="text-muted">Access your Google Drive files</small>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-primary w-100">Connect</button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <i class="bi bi-dropbox fs-1 text-primary me-3"></i>
                                                <div>
                                                    <h6 class="mb-0">Dropbox</h6>
                                                    <small class="text-muted">Connect your Dropbox account</small>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-primary w-100">Connect</button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <i class="bi bi-github fs-1 text-primary me-3"></i>
                                                <div>
                                                    <h6 class="mb-0">GitHub</h6>
                                                    <small class="text-muted">Link your GitHub repositories</small>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-primary w-100">Connect</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Invite Member Modal -->
<div class="modal fade" id="inviteMemberModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Invite Team Member</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="inviteForm">
                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-control" placeholder="colleague@example.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select class="form-select">
                            <option value="admin">Admin</option>
                            <option value="member" selected>Team Member</option>
                            <option value="viewer">Viewer</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message (Optional)</label>
                        <textarea class="form-control" rows="3" placeholder="Add a personal message..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="sendInvite()">Send Invitation</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadBillingHistory();
            loadTeamMembers();
            loadApiKeys();
            loadSecurityData();
        });

        function loadBillingHistory() {
            const history = [
                { date: '2024-03-15', invoice: 'INV-2024-045', amount: 79.00, status: 'Paid' },
                { date: '2024-02-15', invoice: 'INV-2024-032', amount: 79.00, status: 'Paid' },
                { date: '2024-01-15', invoice: 'INV-2024-018', amount: 79.00, status: 'Paid' }
            ];

            let html = '';
            history.forEach(h => {
                html += `
                    <tr>
                        <td>${h.date}</td>
                        <td><a href="#" onclick="viewInvoice('${h.invoice}')">${h.invoice}</a></td>
                        <td>$${h.amount}</td>
                        <td><span class="badge bg-success">${h.status}</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="downloadInvoice('${h.invoice}')">
                                <i class="bi bi-download"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });
            $('#billingHistory').html(html);
        }

        function loadTeamMembers() {
            const members = [
                { name: 'John Doe', email: 'john@acme.com', role: 'Admin', status: 'Active', lastActive: 'Today' },
                { name: 'Jane Smith', email: 'jane@acme.com', role: 'Member', status: 'Active', lastActive: 'Yesterday' },
                { name: 'Bob Johnson', email: 'bob@acme.com', role: 'Viewer', status: 'Pending', lastActive: 'Never' }
            ];

            let html = '';
            members.forEach(m => {
                html += `
                    <tr>
                        <td>${m.name}</td>
                        <td>${m.email}</td>
                        <td><span class="badge bg-info">${m.role}</span></td>
                        <td><span class="badge bg-${m.status === 'Active' ? 'success' : 'warning'}">${m.status}</span></td>
                        <td>${m.lastActive}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="editMember('${m.email}')">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="removeMember('${m.email}')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });
            $('#teamMembers').html(html);
        }

        function loadApiKeys() {
            const keys = [
                { name: 'Production API Key', key: 'pk_live_••••••••••••••', created: '2024-01-15', lastUsed: '2024-03-15' },
                { name: 'Development API Key', key: 'pk_test_••••••••••••••', created: '2024-01-15', lastUsed: '2024-03-14' }
            ];

            let html = '';
            keys.forEach(k => {
                html += `
                    <tr>
                        <td>${k.name}</td>
                        <td><code>${k.key}</code></td>
                        <td>${k.created}</td>
                        <td>${k.lastUsed}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger" onclick="revokeKey('${k.name}')">
                                Revoke
                            </button>
                        </td>
                    </tr>
                `;
            });
            $('#apiKeys').html(html);
        }

        function loadSecurityData() {
            // Load sessions
            const sessions = [
                { device: 'Chrome on Windows', ip: '192.168.1.100', location: 'San Francisco, CA', current: true }
            ];

            let sessionsHtml = '';
            sessions.forEach(s => {
                sessionsHtml += `
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-laptop me-2"></i>
                            <strong>${s.device}</strong>
                            <br>
                            <small class="text-muted">${s.ip} • ${s.location}</small>
                        </div>
                        <div>
                            ${s.current ? '<span class="badge bg-success me-2">Current</span>' : ''}
                            <button class="btn btn-sm btn-outline-danger" onclick="revokeSession('${s.ip}')">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                `;
            });
            $('#securitySessions').html(sessionsHtml);

            // Load login history
            const history = [
                { date: '2024-03-15 10:30:00', ip: '192.168.1.100', device: 'Chrome', location: 'San Francisco, CA' }
            ];

            let historyHtml = '';
            history.forEach(h => {
                historyHtml += `
                    <tr>
                        <td>${h.date}</td>
                        <td>${h.ip}</td>
                        <td>${h.device}</td>
                        <td>${h.location}</td>
                    </tr>
                `;
            });
            $('#securityLoginHistory').html(historyHtml);

            // Load activity log
            const activities = [
                { action: 'Password changed', date: '2024-03-10', icon: 'key', color: 'warning' },
                { action: 'New login from Chrome', date: '2024-03-15', icon: 'box-arrow-in-right', color: 'success' }
            ];

            let activityHtml = '';
            activities.forEach(a => {
                activityHtml += `
                    <div class="timeline-item">
                        <div class="d-flex">
                            <div class="timeline-icon bg-${a.color} bg-opacity-10 text-${a.color} me-3">
                                <i class="bi bi-${a.icon}"></i>
                            </div>
                            <div>
                                <strong>${a.action}</strong>
                                <br>
                                <small class="text-muted">${a.date}</small>
                            </div>
                        </div>
                    </div>
                `;
            });
            $('#securityActivityLog').html(activityHtml);
        }

        function addPaymentMethod() {
            alert('Add payment method form would open here');
        }

        function changePlan() {
            alert('Change plan options would open here');
        }

        function inviteMember() {
            $('#inviteMemberModal').modal('show');
        }

        function sendInvite() {
            $('#inviteMemberModal').modal('hide');
            showNotification('Invitation sent successfully', 'success');
        }

        function generateApiKey() {
            if (confirm('Generate new API key? Old key will be revoked.')) {
                showNotification('New API key generated', 'success');
            }
        }

        function revokeKey(keyName) {
            if (confirm(`Revoke ${keyName}?`)) {
                showNotification('Key revoked', 'success');
            }
        }

        function setup2FA() {
            alert('Two-factor authentication setup would open here');
        }

        function editMember(email) {
            alert(`Edit member: ${email}`);
        }

        function removeMember(email) {
            if (confirm(`Remove ${email} from team?`)) {
                showNotification('Member removed', 'success');
            }
        }

        function viewInvoice(invoiceNumber) {
            window.location.href = `/Client/Invoice/${invoiceNumber}`;
        }

        function downloadInvoice(invoiceNumber) {
            window.location.href = `/api/client/invoices/${invoiceNumber}/pdf`;
        }

        function revokeSession(ip) {
            if (confirm('Revoke this session?')) {
                showNotification('Session revoked', 'success');
            }
        }

        function showNotification(message, type) {
            alert(message);
        }
    </script>
}